{
  "version": 2,
  "builds": [
    {
      "src": "serverless.js",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/serverless.js"
    },
    {
      "src": "/",
      "dest": "/serverless.js"
    }
  ]
}
